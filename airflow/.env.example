AIRFLOW_FERNET_KEY=GENERATE_WITH_python_-c_'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
POSTGRES_PASSWORD=realestate_secret_2026
GEMINI_API_KEY=
COHERE_API_KEY=
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_MAIL_FROM=airflow@example.com
# Comma-separated list, e.g. ops@example.com,oncall@example.com
ALERT_EMAIL_RECIPIENTS=

# Preconditions before `docker compose -f airflow/docker-compose.airflow.yml up`:
# 1. Bring up the root `docker-compose.yml` once so the external network
#    `realestate_chatbot_v2_default` exists. Verify with:
#      docker network inspect realestate_chatbot_v2_default
# 2. After the stack is up, create the `realestate_app` Airflow connection
#    (Admin -> Connections -> Add) with host=realestate_postgres, port=5432,
#    schema=realestate, login=admin, password=${POSTGRES_PASSWORD}. The
#    `mark_active` task in daily_listings_dag depends on this connection.
