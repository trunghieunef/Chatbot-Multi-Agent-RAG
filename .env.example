# ============================================
# Real Estate Chatbot v2 — Environment Config
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets!

# --- Database ---
POSTGRES_DB=realestate
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://admin:change-me@postgres:5432/realestate

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Backend ---
DEBUG=false
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_URL=http://backend:8000

# --- Domain (for nginx SSL) ---
DOMAIN=your-domain.com

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_JUDGE_MODEL=gemini-2.0-flash

# --- Embedding ---
HF_EMBEDDING_MODEL=BAAI/bge-m3
COHERE_API_KEY=

# --- Agent Service ---
AGENT_SERVICE_URL=http://agent-service:8100
AGENT_INTERNAL_KEY=change-me-internal-agent-key
CHATBOT_AGENT_SERVICE_ENABLED=true

# --- Agent Routing & Features ---
AGENT_ROUTER_MODE=rule
AGENT_QUERY_REWRITE_ENABLED=false
AGENT_SPECIALIST_LLM_ENABLED=false
AGENT_MEMORY_FILTERS_ENABLED=false
AGENT_LLM_COST_TRACKING_ENABLED=true

# --- Agent Timeouts (seconds) ---
AGENT_TOTAL_TIMEOUT_SECONDS=45
AGENT_LLM_ROUTER_TIMEOUT_SECONDS=8
AGENT_LLM_QUERY_TIMEOUT_SECONDS=8
AGENT_SPECIALIST_LLM_TIMEOUT_SECONDS=20

# --- Chatbot ---
INTENT_EXTRACTOR=rule
CHATBOT_EMBEDDING_LOCAL_FILES_ONLY=true
CHATBOT_LLM_JUDGE_ENABLED=false
CHATBOT_MEMORY_ENABLED=true
CHATBOT_ADMIN_ENABLED=true
CHATBOT_TRACE_LEVEL=full

# --- Chat Limits ---
ANON_CHAT_DAILY_LIMIT=20
AUTH_CHAT_DAILY_LIMIT=200
